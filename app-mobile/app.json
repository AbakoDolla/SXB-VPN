{
  "expo": {
    "name": "SXB VPN",
    "slug": "sxb-vpn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sxb-vpn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080B14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sxbvpn.app"
    },
    "android": {
      "package": "com.sxbvpn.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#080B14"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "./plugins/withCrashLogger.js"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
