{
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "react-native",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./*"],
      "react": ["../node_modules/react"],
      "react-native": ["../node_modules/react-native"],
      "expo-secure-store": ["../node_modules/expo-secure-store"],
      "@react-native-async-storage/async-storage": ["../node_modules/@react-native-async-storage/async-storage"],
      "expo-constants": ["../node_modules/expo-constants"],
      "expo-router": ["../node_modules/expo-router"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "references": [
    {
      "path": "../lib/api-client-react"
    }
  ]
}
